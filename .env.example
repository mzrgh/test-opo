# ─── Supabase ───────────────────────────────────────────────────────────────
# URL del proyecto (Settings → API → Project URL)
SUPABASE_URL=https://TU-PROYECTO.supabase.co
# service_role key (Settings → API → Project API keys → service_role).
# Es SECRETA y solo se usa en servidor. Nunca la expongas al navegador.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# ─── Proveedor de generación ─────────────────────────────────────────────────
# Qué LLM genera los tests: "anthropic" (lee el PDF nativo), "deepseek" o "zai"
# (más baratos, pero NO leen PDFs: el temario se extrae a texto con unpdf; los
# PDFs escaneados sin OCR no funcionan). Por defecto: anthropic.
LLM_PROVIDER=anthropic

# ─── Claude (Anthropic) ──────────────────────────────────────────────────────
# Necesario si LLM_PROVIDER=anthropic. API key de console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
# Modelo de generación. Por defecto el Opus más capaz (calidad en oposiciones).
# Para abaratar costes puedes usar: claude-sonnet-4-6
ANTHROPIC_MODEL=claude-opus-4-8

# ─── DeepSeek ────────────────────────────────────────────────────────────────
# Necesario si LLM_PROVIDER=deepseek. API key de platform.deepseek.com
DEEPSEEK_API_KEY=sk-...
# Modelo. Por defecto deepseek-v4-flash (1M de contexto, modo JSON).
# NO uses deepseek-chat/deepseek-reasoner: se deprecan el 2026/07/24.
DEEPSEEK_MODEL=deepseek-v4-flash

# ─── z.ai (GLM) ──────────────────────────────────────────────────────────────
# Necesario si LLM_PROVIDER=zai. API key de z.ai (https://z.ai).
ZAI_API_KEY=tu-zai-api-key
# Modelo. Por defecto glm-4.7-flashx (200K de contexto, 128K de salida, modo JSON).
ZAI_MODEL=glm-4.7-flashx
